  "folder_templates": [
    {
      "folder": "raw/books",
      "template": "config/templates/capitulo-livro.md"
    },
    {
      "folder": "raw/articles",
      "template": "config/templates/artigo.md"
    },
    {
      "folder": "raw/recipes",
      "template": "config/templates/recipe.md"
    }
  ],
  "enable_file_templates": false,
  "file_templates": [
    {
      "regex": ".*",
      "template": ""
    }
  ],
  "syntax_highlighting": true,
  "syntax_highlighting_mobile": false,
  "enabled_templates_hotkeys": [""],
  "startup_templates": [""]
